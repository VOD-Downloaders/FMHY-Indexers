{
	"name": "Cineby",
	"url": "https://cineby.sc/",
	"mirrors": ["https://cineplay.to/", "https://fmovies.nz/"],
	"uses_cloudflare": false,
	"download": {
		"segment_pre_download": {
			"segment_timeout": 5,
			"segment_attempts": 5,
			"headers": { 
				"Referer": "{base_url}" 
			}
		},
		"segment_post_download": {
			"remove_front_bytes": 0,
			"remove_back_bytes": 0
		},
		"method": {
			"type": "index",
			"wait_time": 6,
			"retries": 5
		}
	}
}
