{
	"name": "Aether",
	"url": "https://aether.bar/",
	"mirrors": [
		"https://aether.cx/"
	],
	"uses_cloudflare": false,
	"download": {
		"segment_pre_download": {
			"segment_timeout": 5,
			"segment_attempts": 5,
			"headers": {
				"Referer": "{base_url}"
			}
		},
		"segment_post_download": {
			"remove_front_bytes": 8,
			"remove_back_bytes": 0
		},
		"method": {
			"type": "master",
			"wait_time": 5,
			"retries": 3
		}
	}
}
